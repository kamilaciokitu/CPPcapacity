<script>
/* ════════════════════════════════════════
   PASSWORD — change this string to set a new password
   ITU-D Connectivity Planning Platform Workshop
   ════════════════════════════════════════ */
const SESSION_PASSWORD = 'cpp2024';

/* ── Auth ── */
function checkPassword() {
  const val = document.getElementById('pw-input').value;
  const err = document.getElementById('lock-error');
  if (val === SESSION_PASSWORD) {
    document.getElementById('lock-screen').style.display = 'none';
    document.getElementById('app').style.display = 'block';
    sessionStorage.setItem('cpp_auth', '1');
    renderExplore('all');
    renderMap();
    renderPriority();
    renderQuiz();
  } else {
    err.style.display = 'block';
    document.getElementById('pw-input').value = '';
    document.getElementById('pw-input').focus();
  }
}

function logout() {
  sessionStorage.removeItem('cpp_auth');
  document.getElementById('app').style.display = 'none';
  document.getElementById('lock-screen').style.display = 'flex';
  document.getElementById('pw-input').value = '';
  document.getElementById('lock-error').style.display = 'none';
}

document.getElementById('pw-input').addEventListener('keydown', e => {
  if (e.key === 'Enter') checkPassword();
});

if (sessionStorage.getItem('cpp_auth') === '1') {
  document.getElementById('lock-screen').style.display = 'none';
  document.getElementById('app').style.display = 'block';
  setTimeout(() => {
    renderExplore('all'); renderMap(); renderPriority(); renderQuiz();
  }, 50);
}

/* ── Data ── */
const districts = [
  { name:"Northern Highlands",  pop:245000, cov4g:12, bb:8,    rural:0.92, income:1, ops:1, usf:true },
  { name:"Eastern Plains",      pop:312000, cov4g:18, bb:12,   rural:0.85, income:1, ops:1, usf:true },
  { name:"Coastal North",       pop:198000, cov4g:72, bb:45,   rural:0.35, income:3, ops:2, usf:false },
  { name:"Central Basin",       pop:520000, cov4g:88, bb:61,   rural:0.18, income:4, ops:3, usf:false },
  { name:"Southern Lowlands",   pop:178000, cov4g:24, bb:null, rural:0.78, income:2, ops:1, usf:true },
  { name:"River Delta",         pop:290000, cov4g:65, bb:38,   rural:0.42, income:3, ops:2, usf:false },
  { name:"Mountain West",       pop:142000, cov4g:8,  bb:5,    rural:0.96, income:1, ops:1, usf:true },
  { name:"Urban Capital",       pop:890000, cov4g:97, bb:82,   rural:0.05, income:5, ops:4, usf:false },
  { name:"Suburban East",       pop:445000, cov4g:84, bb:67,   rural:0.22, income:4, ops:3, usf:false },
  { name:"Interior Plateau",    pop:167000, cov4g:31, bb:14,   rural:0.71, income:2, ops:1, usf:true },
  { name:"Lake Region",         pop:203000, cov4g:55, bb:29,   rural:0.55, income:3, ops:2, usf:true },
  { name:"Southern Border",     pop:134000, cov4g:22, bb:null, rural:0.82, income:1, ops:1, usf:true },
  { name:"Coastal South",       pop:267000, cov4g:76, bb:52,   rural:0.28, income:4, ops:3, usf:false },
  { name:"Northern Valley",     pop:189000, cov4g:44, bb:21,   rural:0.63, income:2, ops:2, usf:true },
  { name:"Western Savanna",     pop:221000, cov4g:28, bb:11,   rural:0.75, income:2, ops:1, usf:true },
  { name:"Central East",        pop:358000, cov4g:69, bb:41,   rural:0.38, income:3, ops:2, usf:false },
  { name:"Port District",       pop:412000, cov4g:91, bb:74,   rural:0.12, income:5, ops:3, usf:false },
  { name:"Inland Marshes",      pop:156000, cov4g:16, bb:7,    rural:0.88, income:1, ops:1, usf:true }
];

function getCoverageColor(val, type) {
  if (val === null) return '#B4B2A9';
  if (type === '4g' || type === 'broadband') {
    if (val < 30) return '#E24B4A'; if (val < 50) return '#EF9F27';
    if (val < 70) return '#FAC775'; if (val < 85) return '#9FE1CB'; return '#0F6E56';
  }
  if (type === 'rurality') {
    if (val > 0.8) return '#E24B4A'; if (val > 0.6) return '#EF9F27';
    if (val > 0.4) return '#FAC775'; if (val > 0.2) return '#9FE1CB'; return '#0F6E56';
  }
  if (type === 'income') return ['#E24B4A','#EF9F27','#FAC775','#9FE1CB','#0F6E56'][val-1];
  return '#B4B2A9';
}

/* ── Panel nav ── */
function showPanel(id) {
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-tab').forEach(t => { t.classList.remove('active'); t.setAttribute('aria-selected','false'); });
  document.getElementById('panel-' + id).classList.add('active');
  const idx = {intro:0,upload:1,explore:2,map:3,insights:4,priority:5,quiz:6}[id];
  const tab = document.querySelectorAll('.nav-tab')[idx];
  tab.classList.add('active'); tab.setAttribute('aria-selected','true');
  if (id === 'explore') renderExplore('all');
  if (id === 'map') renderMap();
  if (id === 'priority') renderPriority();
}

/* ── Upload simulation ── */
function simulateUpload() {
  document.getElementById('upload-title').textContent = 'Processing file…';
  document.getElementById('upload-desc').textContent = 'Validating columns and checking for missing values';
  document.getElementById('upload-hint').textContent = '';
  setTimeout(loadSample, 900);
}

function loadSample() {
  document.getElementById('dataset-info').style.display = 'block';
  document.getElementById('load-sample-btn').style.display = 'none';
  const zone = document.getElementById('upload-zone');
  zone.classList.add('loaded');
  document.getElementById('upload-icon').classList.add('loaded-icon');
  document.getElementById('upload-icon').classList.replace('ti-upload','ti-circle-check');
  document.getElementById('upload-title').textContent = 'File loaded successfully';
  document.getElementById('upload-desc').textContent = 'sample_coverage_dataset.csv · 18 records';
  document.getElementById('upload-hint').textContent = '';
}

/* ── Explore / table ── */
function filterTable(filter, btn) {
  document.querySelectorAll('#coverage-filters .filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  renderExplore(filter);
}

function renderExplore(filter) {
  let filtered = districts;
  if (filter === 'critical') filtered = districts.filter(d => d.cov4g < 30);
  else if (filter === 'moderate') filtered = districts.filter(d => d.cov4g >= 30 && d.cov4g <= 70);
  else if (filter === 'good') filtered = districts.filter(d => d.cov4g > 70);
  else if (filter === 'usf') filtered = districts.filter(d => d.usf);

  const tbody = document.getElementById('district-tbody');
  tbody.innerHTML = filtered.map(d => {
    const band = d.cov4g < 30 ? 'critical' : d.cov4g <= 70 ? 'moderate' : 'good';
    const tagCls = band === 'critical' ? 'tag-red' : band === 'moderate' ? 'tag-amber' : 'tag-green';
    const tagLabel = band === 'critical' ? 'Critical' : band === 'moderate' ? 'Moderate' : 'Well served';
    return `<tr>
      <td style="font-weight:500;">${d.name}</td>
      <td>${(d.pop/1000).toFixed(0)}k</td>
      <td><div style="display:flex;align-items:center;gap:8px;">
        <div class="progress-bar-wrap" style="width:70px;"><div class="progress-bar" style="width:${d.cov4g}%;background:${getCoverageColor(d.cov4g,'4g')};"></div></div>
        <span style="font-size:12px;">${d.cov4g}%</span></div></td>
      <td>${d.bb !== null ? d.bb + '%' : '<span class="tag tag-gray">N/A</span>'}</td>
      <td>${d.rural.toFixed(2)}</td>
      <td style="text-align:center;">${d.income}</td>
      <td style="text-align:center;">${d.usf ? '<span class="tag tag-green">Yes</span>' : '<span class="tag tag-gray">No</span>'}</td>
      <td><span class="tag ${tagCls}">${tagLabel}</span></td>
    </tr>`;
  }).join('');

  const barArea = document.getElementById('bar-chart-area');
  const sorted = [...filtered].sort((a,b) => a.cov4g - b.cov4g);
  barArea.innerHTML = sorted.map(d => `
    <div style="display:flex;align-items:center;gap:8px;margin-bottom:5px;">
      <div style="font-size:11px;min-width:130px;text-align:right;color:var(--text-secondary);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${d.name}</div>
      <div style="flex:1;"><div class="progress-bar-wrap"><div class="progress-bar" style="width:${d.cov4g}%;background:${getCoverageColor(d.cov4g,'4g')};"></div></div></div>
      <div style="font-size:11px;min-width:28px;font-weight:500;">${d.cov4g}%</div>
    </div>`).join('');
}

/* ── Map ── */
let currentMapType = '4g';
let showUSF = false;

function updateMap(type, btn) {
  document.querySelectorAll('#map-filters .filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  currentMapType = type;
  renderMap();
}

function toggleUSF() {
  showUSF = document.getElementById('usf-overlay').checked;
  renderMap();
}

function renderMap() {
  const titles = { '4g':'4G mobile coverage by district', broadband:'Fixed broadband coverage by district', rurality:'Rurality index by district (1 = fully rural)', income:'Income quintile by district (1 = lowest)' };
  document.getElementById('map-title').textContent = titles[currentMapType];

  const legends = {
    '4g': '<span class="legend-item"><span class="legend-dot" style="background:#E24B4A;"></span>&lt; 30%</span><span class="legend-item"><span class="legend-dot" style="background:#EF9F27;"></span>30–50%</span><span class="legend-item"><span class="legend-dot" style="background:#FAC775;"></span>50–70%</span><span class="legend-item"><span class="legend-dot" style="background:#9FE1CB;"></span>70–85%</span><span class="legend-item"><span class="legend-dot" style="background:#0F6E56;"></span>&gt; 85%</span>',
    broadband: '<span class="legend-item"><span class="legend-dot" style="background:#E24B4A;"></span>&lt; 30%</span><span class="legend-item"><span class="legend-dot" style="background:#EF9F27;"></span>30–50%</span><span class="legend-item"><span class="legend-dot" style="background:#9FE1CB;"></span>50–70%</span><span class="legend-item"><span class="legend-dot" style="background:#0F6E56;"></span>&gt; 70%</span><span class="legend-item"><span class="legend-dot" style="background:#B4B2A9;"></span>No data</span>',
    rurality: '<span class="legend-item"><span class="legend-dot" style="background:#0F6E56;"></span>Urban</span><span class="legend-item"><span class="legend-dot" style="background:#9FE1CB;"></span>Peri-urban</span><span class="legend-item"><span class="legend-dot" style="background:#FAC775;"></span>Mixed</span><span class="legend-item"><span class="legend-dot" style="background:#EF9F27;"></span>Rural</span><span class="legend-item"><span class="legend-dot" style="background:#E24B4A;"></span>Remote</span>',
    income: '<span class="legend-item"><span class="legend-dot" style="background:#E24B4A;"></span>Q1 (lowest)</span><span class="legend-item"><span class="legend-dot" style="background:#EF9F27;"></span>Q2</span><span class="legend-item"><span class="legend-dot" style="background:#FAC775;"></span>Q3</span><span class="legend-item"><span class="legend-dot" style="background:#9FE1CB;"></span>Q4</span><span class="legend-item"><span class="legend-dot" style="background:#0F6E56;"></span>Q5 (highest)</span>'
  };
  document.getElementById('map-legend').innerHTML = legends[currentMapType];

  const vals = { '4g': d => d.cov4g, broadband: d => d.bb, rurality: d => d.rural, income: d => d.income };
  const grid = document.getElementById('map-grid');
  grid.innerHTML = districts.map((d,i) => {
    const raw = vals[currentMapType](d);
    const colorVal = currentMapType === 'rurality' ? d.rural : currentMapType === 'income' ? d.income : raw;
    const color = getCoverageColor(colorVal, currentMapType);
    const usfBorder = showUSF && d.usf ? 'border:2.5px solid #185FA5;' : '';
    const shortName = d.name.split(' ').slice(0,2).join(' ');
    return `<div class="map-cell" style="background:${color};${usfBorder}" onclick="showDistrictDetail(${i})" role="button" tabindex="0" aria-label="${d.name}">
      <span class="cell-label">${shortName}</span>
    </div>`;
  }).join('');
}

function showDistrictDetail(idx) {
  const d = districts[idx];
  document.getElementById('detail-title').textContent = d.name;
  document.getElementById('detail-content').innerHTML = `
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:6px;margin-bottom:10px;">
      <div class="metric" style="padding:0.6rem 0.75rem;"><div class="metric-label">4G coverage</div><div class="metric-value" style="font-size:18px;color:${getCoverageColor(d.cov4g,'4g')};">${d.cov4g}%</div></div>
      <div class="metric" style="padding:0.6rem 0.75rem;"><div class="metric-label">Fixed broadband</div><div class="metric-value" style="font-size:18px;">${d.bb !== null ? d.bb + '%' : '—'}</div></div>
    </div>
    <table style="width:100%;font-size:12px;">
      <tr><td style="color:var(--text-secondary);padding:3px 0;">Population</td><td style="text-align:right;font-weight:500;">${(d.pop/1000).toFixed(0)}k</td></tr>
      <tr><td style="color:var(--text-secondary);padding:3px 0;">Rurality index</td><td style="text-align:right;font-weight:500;">${d.rural.toFixed(2)}</td></tr>
      <tr><td style="color:var(--text-secondary);padding:3px 0;">Income quintile</td><td style="text-align:right;font-weight:500;">Q${d.income}</td></tr>
      <tr><td style="color:var(--text-secondary);padding:3px 0;">Active operators</td><td style="text-align:right;font-weight:500;">${d.ops}</td></tr>
      <tr><td style="color:var(--text-secondary);padding:3px 0;">USF eligible</td><td style="text-align:right;">${d.usf ? '<span class="tag tag-green">Yes</span>' : '<span class="tag tag-gray">No</span>'}</td></tr>
    </table>
    <div style="margin-top:8px;font-size:11px;color:var(--text-tertiary);">${d.usf ? 'Qualifies for Universal Service Fund support.' : 'Does not currently qualify for USF support.'}</div>`;
}

/* ── Priority ── */
function updatePriority() {
  const wc = +document.getElementById('w-coverage').value;
  const wp = +document.getElementById('w-pop').value;
  const wi = +document.getElementById('w-income').value;
  const wr = +document.getElementById('w-rural').value;
  document.getElementById('w-coverage-val').textContent = wc + '%';
  document.getElementById('w-pop-val').textContent = wp + '%';
  document.getElementById('w-income-val').textContent = wi + '%';
  document.getElementById('w-rural-val').textContent = wr + '%';
  document.getElementById('total-weight').textContent = (wc+wp+wi+wr) + '%';
  renderPriority(wc, wp, wi, wr);
}

function renderPriority(wc, wp, wi, wr) {
  if (!wc) { wc=40; wp=30; wi=20; wr=10; }
  const maxPop = Math.max(...districts.map(d => d.pop));
  const scored = districts.filter(d => d.usf).map(d => ({
    ...d,
    score: (wc * (100-d.cov4g)/100 + wp * d.pop/maxPop + wi * (6-d.income)/5 + wr * d.rural) / 100
  })).sort((a,b) => b.score - a.score);

  document.getElementById('priority-list').innerHTML = scored.slice(0,8).map((d,i) => {
    const rc = i < 3 ? 'r-high' : i < 6 ? 'r-med' : 'r-low';
    return `<div class="priority-item">
      <div class="priority-rank ${rc}">${i+1}</div>
      <div class="priority-info">
        <div class="p-name">${d.name}</div>
        <div class="p-detail">${d.cov4g}% 4G · ${(d.pop/1000).toFixed(0)}k people · Q${d.income} income</div>
      </div>
      <div style="font-size:12px;font-weight:500;color:var(--text-secondary);">${(d.score*100).toFixed(0)}pts</div>
    </div>`;
  }).join('');

  const top5 = scored.slice(0,5).reduce((s,d) => s+d.score, 0);
  const all = scored.reduce((s,d) => s+d.score, 0);
  document.getElementById('usf-alloc').textContent = (all > 0 ? Math.round(top5/all*100) : 0) + '%';
}

/* ── Quiz ── */
const quizData = [
  { q:"A district has 4G coverage of 22% and a population of 300,000. What does this tell a broadband planner?",
    options:["The district is performing well and doesn't need intervention","Approximately 234,000 people likely lack meaningful mobile connectivity — a critical coverage gap requiring prioritisation","The data is too limited to draw any conclusions","The district should be deprioritised in favour of urban areas"],
    correct:1, explain:"22% coverage means roughly 78% of the population — about 234,000 people — are without 4G access. Combined with the population size, this signals a high-impact intervention opportunity." },
  { q:"In a geospatial connectivity map, a cluster of red districts in the north-east corner all have income quintile 1 or 2. What is the most likely policy interpretation?",
    options:["The operators need higher prices in those areas","Geographic and economic factors are combining to create a market failure — commercial operators have no incentive to serve these areas","The data collection is probably wrong","This is normal and expected — all countries have some red districts"],
    correct:1, explain:"When low coverage correlates with low income and geographic isolation, it indicates classic market failure. Public intervention (USF, subsidies) is necessary where commercial operators cannot recover investment costs." },
  { q:"A dataset has two null values in the 'fixed_broadband_pct' column. What is the best approach?",
    options:["Delete those two rows entirely from all analyses","Replace with zero — missing data is the same as no coverage","Flag the missing values, use the district average for broadband-specific analyses, and retain the full rows for mobile coverage analysis","Assume the broadband coverage is 100% since the data wasn't reported"],
    correct:2, explain:"Missing values should be handled thoughtfully. Deleting rows wastes valid data in other columns. Assuming zero or 100% introduces bias. The best approach retains rows for non-missing variables and uses context-appropriate imputation." },
  { q:"Seven districts have high 4G coverage (>70%) but fixed broadband below 20%. What does this suggest for infrastructure policy?",
    options:["These districts should be ignored — they have good mobile coverage","Fixed wireless access (FWA) could be a cost-efficient solution, leveraging existing mast infrastructure to deliver broadband","The broadband data must be wrong — high mobile coverage always means high broadband","These districts should receive the same USF intervention as rural low-coverage districts"],
    correct:1, explain:"Existing mobile mast infrastructure reduces deployment costs for fixed wireless broadband. This pattern suggests a specific, lower-cost intervention pathway distinct from areas with no infrastructure at all." },
  { q:"You are weighting a USF prioritisation model. Which combination of weights best reflects a 'pro-poor' targeting approach?",
    options:["Coverage gap 70%, population 30%, income vulnerability 0%, rurality 0%","Coverage gap 20%, population 10%, income vulnerability 50%, rurality 20%","Coverage gap 25%, population 25%, income vulnerability 25%, rurality 25%","Coverage gap 10%, population 80%, income vulnerability 5%, rurality 5%"],
    correct:1, explain:"A 'pro-poor' approach prioritises income vulnerability as the dominant criterion, ensuring USF resources reach the most economically disadvantaged communities rather than simply the largest unserved populations." }
];

let quizAnswers = {};
function renderQuiz() {
  const answered = Object.keys(quizAnswers).length;
  const correct = Object.values(quizAnswers).filter(Boolean).length;
  let html = '';
  if (answered === quizData.length) {
    html = `<div class="card" style="text-align:center;padding:1.5rem;margin-bottom:1rem;">
      <div style="font-size:32px;font-weight:500;color:${correct>=4?'var(--green)':'var(--amber)'};margin-bottom:8px;">${correct} / ${quizData.length}</div>
      <div style="font-size:14px;color:var(--text-secondary);">${correct>=4?'Excellent work — strong foundational understanding of CPP methodology.':'Good effort. Review the insights and map sections to strengthen your understanding.'}</div>
    </div>`;
  }
  html += quizData.map((q,qi) => {
    const isAnswered = quizAnswers[qi] !== undefined;
    return `<div class="card" style="margin-bottom:1rem;">
      <div style="font-size:13px;font-weight:500;margin-bottom:0.75rem;"><span style="color:var(--green);">Q${qi+1}.</span> ${q.q}</div>
      ${q.options.map((opt,oi) => {
        let cls = 'quiz-option' + (isAnswered ? ' answered' : '');
        if (isAnswered && oi === q.correct) cls += ' correct';
        else if (isAnswered && oi === quizAnswers[qi] && oi !== q.correct) cls += ' wrong';
        return `<div class="${cls}" onclick="${isAnswered?'':(`answerQuiz(${qi},${oi})`)}">
          <div class="quiz-letter">${String.fromCharCode(65+oi)}</div>
          <div style="font-size:13px;">${opt}</div>
        </div>`;
      }).join('')}
      ${isAnswered ? `<div class="insight-box ${quizAnswers[qi]===q.correct?'insight-green':'insight-amber'}" style="margin-top:0.5rem;margin-bottom:0;">
        <div class="ins-title ${quizAnswers[qi]===q.correct?'ins-green':'ins-amber'}">${quizAnswers[qi]===q.correct?'✓ Correct':'✗ Not quite'}</div>
        <p>${q.explain}</p></div>` : ''}
    </div>`;
  }).join('');
  document.getElementById('quiz-container').innerHTML = html;
}

function answerQuiz(qi, oi) { quizAnswers[qi] = (oi === quizData[qi].correct); renderQuiz(); }
function resetQuiz() { quizAnswers = {}; renderQuiz(); }
</script>
</body>
</html>
