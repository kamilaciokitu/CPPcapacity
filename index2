<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ITU-D CPP Workshop — From Data to Visualisation</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.19.0/dist/tabler-icons.min.css">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --bg-primary: #ffffff;
    --bg-secondary: #f5f4f0;
    --bg-tertiary: #eeece8;
    --text-primary: #1a1a18;
    --text-secondary: #6b6a65;
    --text-tertiary: #9a9994;
    --border-light: rgba(0,0,0,0.10);
    --border-mid: rgba(0,0,0,0.18);
    --border-strong: rgba(0,0,0,0.28);
    --radius-md: 8px;
    --radius-lg: 12px;
    --radius-xl: 16px;
    --green: #1D9E75;
    --green-light: #E1F5EE;
    --green-dark: #0F6E56;
    --amber: #EF9F27;
    --amber-light: #FAEEDA;
    --amber-dark: #854F0B;
    --red: #E24B4A;
    --red-light: #FCEBEB;
    --red-dark: #A32D2D;
    --blue: #378ADD;
    --blue-light: #E6F1FB;
    --blue-dark: #185FA5;
    --gray-light: #F1EFE8;
    --gray: #888780;
    --gray-dark: #5F5E5A;
    --font-sans: system-ui, -apple-system, 'Segoe UI', sans-serif;
  }
  @media (prefers-color-scheme: dark) {
    :root {
      --bg-primary: #1e1e1c;
      --bg-secondary: #2a2a27;
      --bg-tertiary: #232320;
      --text-primary: #f0ede8;
      --text-secondary: #a8a49e;
      --text-tertiary: #6b6760;
      --border-light: rgba(255,255,255,0.08);
      --border-mid: rgba(255,255,255,0.14);
      --border-strong: rgba(255,255,255,0.22);
      --green-light: #063d2b;
      --amber-light: #3d2800;
      --red-light: #3d1010;
      --blue-light: #0d2540;
      --gray-light: #2a2a27;
    }
  }
  html, body { height: 100%; font-family: var(--font-sans); background: var(--bg-tertiary); color: var(--text-primary); }

  /* ── LOCK SCREEN ── */
  #lock-screen {
    position: fixed; inset: 0; background: var(--bg-tertiary);
    display: flex; align-items: center; justify-content: center; z-index: 9999;
  }
  .lock-card {
    background: var(--bg-primary); border: 0.5px solid var(--border-mid);
    border-radius: var(--radius-xl); padding: 2.5rem 2rem; width: 340px; text-align: center;
    box-shadow: 0 8px 32px rgba(0,0,0,0.08);
  }
  .lock-icon { font-size: 36px; color: var(--green); margin-bottom: 1rem; display: block; }
  .lock-title { font-size: 18px; font-weight: 500; margin-bottom: 4px; }
  .lock-sub { font-size: 13px; color: var(--text-secondary); margin-bottom: 1.5rem; }
  .lock-input {
    width: 100%; padding: 10px 14px; font-size: 14px; font-family: var(--font-sans);
    background: var(--bg-secondary); color: var(--text-primary);
    border: 0.5px solid var(--border-mid); border-radius: var(--radius-md);
    outline: none; margin-bottom: 0.75rem; letter-spacing: 0.05em;
  }
  .lock-input:focus { border-color: var(--green); box-shadow: 0 0 0 3px rgba(29,158,117,0.15); }
  .lock-btn {
    width: 100%; padding: 10px; font-size: 14px; font-weight: 500; font-family: var(--font-sans);
    background: var(--green); color: #fff; border: none; border-radius: var(--radius-md);
    cursor: pointer; transition: opacity 0.15s;
  }
  .lock-btn:hover { opacity: 0.88; }
  .lock-error { font-size: 12px; color: var(--red); margin-top: 0.5rem; display: none; }
  .lock-hint { font-size: 11px; color: var(--text-tertiary); margin-top: 1rem; }

  /* ── APP SHELL ── */
  #app { display: none; min-height: 100vh; }
  .topbar {
    background: var(--bg-primary); border-bottom: 0.5px solid var(--border-light);
    padding: 0.75rem 1.5rem; display: flex; align-items: center; gap: 12px;
    position: sticky; top: 0; z-index: 100;
  }
  .topbar-brand { font-size: 13px; font-weight: 500; color: var(--text-primary); }
  .topbar-sub { font-size: 12px; color: var(--text-secondary); }
  .topbar-right { margin-left: auto; }
  .btn-logout { font-size: 12px; padding: 5px 12px; border-radius: var(--radius-md); border: 0.5px solid var(--border-mid); background: transparent; color: var(--text-secondary); cursor: pointer; font-family: var(--font-sans); transition: all 0.15s; }
  .btn-logout:hover { border-color: var(--border-strong); color: var(--text-primary); }

  .main { max-width: 860px; margin: 0 auto; padding: 1.5rem 1rem 3rem; }

  /* ── NAV TABS ── */
  .nav { display: flex; gap: 0; border-bottom: 0.5px solid var(--border-light); margin-bottom: 1.5rem; overflow-x: auto; }
  .nav-tab { padding: 0.6rem 1.1rem; font-size: 13px; color: var(--text-secondary); cursor: pointer; border-bottom: 2px solid transparent; white-space: nowrap; background: none; border-top: none; border-left: none; border-right: none; font-family: var(--font-sans); transition: color 0.15s; }
  .nav-tab.active { color: var(--text-primary); border-bottom-color: var(--green); font-weight: 500; }
  .nav-tab:hover:not(.active) { color: var(--text-primary); }
  .step-badge { display: inline-flex; align-items: center; justify-content: center; width: 18px; height: 18px; border-radius: 50%; background: var(--green-light); color: var(--green-dark); font-size: 10px; font-weight: 500; margin-right: 5px; }
  .nav-tab.active .step-badge { background: var(--green); color: #fff; }

  /* ── PANELS ── */
  .panel { display: none; }
  .panel.active { display: block; }

  /* ── COMPONENTS ── */
  .section-label { font-size: 11px; font-weight: 500; color: var(--text-tertiary); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.75rem; }
  .card { background: var(--bg-primary); border: 0.5px solid var(--border-light); border-radius: var(--radius-lg); padding: 1rem 1.25rem; margin-bottom: 1rem; }
  .card-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem; }
  .card-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0.75rem; margin-bottom: 1rem; }
  .metric { background: var(--bg-secondary); border-radius: var(--radius-md); padding: 0.875rem 1rem; }
  .metric-label { font-size: 12px; color: var(--text-secondary); margin-bottom: 4px; }
  .metric-value { font-size: 22px; font-weight: 500; color: var(--text-primary); }
  .metric-sub { font-size: 11px; color: var(--text-tertiary); margin-top: 2px; }

  .tag { display: inline-block; font-size: 11px; padding: 3px 8px; border-radius: 4px; font-weight: 500; }
  .tag-green { background: var(--green-light); color: var(--green-dark); }
  .tag-amber { background: var(--amber-light); color: var(--amber-dark); }
  .tag-red { background: var(--red-light); color: var(--red-dark); }
  .tag-blue { background: var(--blue-light); color: var(--blue-dark); }
  .tag-gray { background: var(--gray-light); color: var(--gray-dark); }

  .upload-zone { border: 1.5px dashed var(--border-mid); border-radius: var(--radius-lg); padding: 2rem; text-align: center; cursor: pointer; transition: background 0.15s; }
  .upload-zone:hover, .upload-zone.loaded { background: var(--bg-secondary); }
  .upload-zone.loaded { border-color: #5DCAA5; }
  .upload-zone i { font-size: 32px; color: var(--text-tertiary); margin-bottom: 0.5rem; display: block; }
  .upload-zone i.loaded-icon { color: var(--green); }
  .upload-zone p { font-size: 13px; color: var(--text-secondary); }

  .data-table { width: 100%; border-collapse: collapse; font-size: 13px; }
  .data-table th { font-size: 11px; font-weight: 500; color: var(--text-secondary); text-align: left; padding: 6px 10px; border-bottom: 0.5px solid var(--border-light); }
  .data-table td { padding: 7px 10px; border-bottom: 0.5px solid var(--border-light); color: var(--text-primary); }
  .data-table tr:last-child td { border-bottom: none; }
  .data-table tr:hover td { background: var(--bg-secondary); }

  .progress-bar-wrap { background: var(--bg-secondary); border-radius: 4px; height: 8px; overflow: hidden; }
  .progress-bar { height: 100%; border-radius: 4px; }

  .insight-box { border-left: 3px solid; padding: 0.75rem 1rem; margin-bottom: 0.75rem; border-radius: 0 4px 4px 0; }
  .insight-green { border-color: var(--green); background: var(--green-light); }
  .insight-amber { border-color: var(--amber); background: var(--amber-light); }
  .insight-red { border-color: var(--red); background: var(--red-light); }
  .insight-blue { border-color: var(--blue); background: var(--blue-light); }
  .insight-box p { font-size: 13px; color: var(--text-primary); line-height: 1.6; }
  .insight-box .ins-title { font-size: 11px; font-weight: 500; margin-bottom: 4px; }
  .ins-green { color: var(--green-dark); }
  .ins-amber { color: var(--amber-dark); }
  .ins-red { color: var(--red-dark); }
  .ins-blue { color: var(--blue-dark); }

  .filter-row { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 1rem; }
  .filter-btn { font-size: 12px; padding: 5px 12px; border-radius: 20px; border: 0.5px solid var(--border-mid); background: var(--bg-primary); color: var(--text-secondary); cursor: pointer; transition: all 0.15s; font-family: var(--font-sans); }
  .filter-btn.active { background: var(--green); color: #fff; border-color: var(--green); }
  .filter-btn:hover:not(.active) { border-color: var(--border-strong); color: var(--text-primary); }

  .legend { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 0.75rem; }
  .legend-item { display: flex; align-items: center; gap: 5px; font-size: 12px; color: var(--text-secondary); }
  .legend-dot { width: 10px; height: 10px; border-radius: 2px; flex-shrink: 0; }

  .map-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 6px; }
  .map-cell { aspect-ratio: 1; border-radius: 6px; position: relative; cursor: pointer; transition: opacity 0.15s; display: flex; align-items: flex-end; padding: 6px; }
  .map-cell:hover { opacity: 0.82; }
  .cell-label { font-size: 10px; font-weight: 500; color: rgba(255,255,255,0.92); line-height: 1.2; text-shadow: 0 1px 3px rgba(0,0,0,0.5); }

  .step-card { display: flex; gap: 1rem; padding: 1rem; border: 0.5px solid var(--border-light); border-radius: var(--radius-lg); margin-bottom: 0.75rem; cursor: pointer; transition: border-color 0.15s; }
  .step-card:hover { border-color: var(--border-strong); }
  .step-num { width: 32px; height: 32px; border-radius: 50%; background: var(--green-light); display: flex; align-items: center; justify-content: center; font-size: 13px; font-weight: 500; color: var(--green-dark); flex-shrink: 0; }
  .step-content p { font-size: 13px; color: var(--text-secondary); margin-top: 3px; line-height: 1.5; }
  .step-content strong { font-size: 14px; font-weight: 500; color: var(--text-primary); }

  .btn-primary { font-size: 13px; padding: 7px 16px; border-radius: var(--radius-md); background: var(--green); color: #fff; border: none; cursor: pointer; font-family: var(--font-sans); transition: opacity 0.15s; }
  .btn-primary:hover { opacity: 0.88; }
  .btn-secondary { font-size: 13px; padding: 7px 16px; border-radius: var(--radius-md); background: var(--bg-secondary); color: var(--text-primary); border: 0.5px solid var(--border-mid); cursor: pointer; font-family: var(--font-sans); transition: background 0.15s; }
  .btn-secondary:hover { background: var(--bg-tertiary); }
  .action-row { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 1rem; }

  .quiz-option { display: flex; align-items: flex-start; gap: 10px; padding: 0.75rem 1rem; border: 0.5px solid var(--border-light); border-radius: var(--radius-md); cursor: pointer; margin-bottom: 0.5rem; transition: all 0.15s; }
  .quiz-option:hover:not(.answered) { border-color: var(--green); background: var(--green-light); }
  .quiz-option.correct { border-color: var(--green); background: var(--green-light); cursor: default; }
  .quiz-option.wrong { border-color: var(--red); background: var(--red-light); cursor: default; }
  .quiz-option.answered { cursor: default; }
  .quiz-letter { width: 24px; height: 24px; border-radius: 50%; background: var(--bg-secondary); display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 500; color: var(--text-secondary); flex-shrink: 0; }

  .priority-item { display: flex; align-items: center; gap: 10px; padding: 0.6rem 0; border-bottom: 0.5px solid var(--border-light); }
  .priority-item:last-child { border-bottom: none; }
  .priority-rank { width: 24px; height: 24px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 500; flex-shrink: 0; }
  .r-high { background: var(--red-light); color: var(--red-dark); }
  .r-med { background: var(--amber-light); color: var(--amber-dark); }
  .r-low { background: var(--green-light); color: var(--green-dark); }
  .priority-info { flex: 1; }
  .priority-info .p-name { font-size: 13px; font-weight: 500; }
  .priority-info .p-detail { font-size: 12px; color: var(--text-secondary); }

  .slider-row { display: flex; align-items: center; gap: 10px; margin-bottom: 0.75rem; }
  .slider-row label { font-size: 13px; color: var(--text-secondary); min-width: 160px; }
  .slider-row input[type=range] { flex: 1; accent-color: var(--green); }
  .slider-row span { font-size: 13px; font-weight: 500; min-width: 36px; text-align: right; color: var(--text-primary); }

  .intro-header { margin-bottom: 1.25rem; }
  .intro-header .eyebrow { font-size: 11px; font-weight: 500; color: var(--green); margin-bottom: 4px; text-transform: uppercase; letter-spacing: 0.08em; }
  .intro-header h1 { font-size: 20px; font-weight: 500; margin-bottom: 4px; }
  .intro-header p { font-size: 13px; color: var(--text-secondary); }

  .divider { border: none; border-top: 0.5px solid var(--border-light); margin: 1rem 0; }

  @media (max-width: 600px) {
    .card-4 { grid-template-columns: 1fr 1fr; }
    .card-row { grid-template-columns: 1fr; }
    .map-grid { grid-template-columns: repeat(3, 1fr); }
  }
</style>
</head>
<body>

<!-- ══════════════════════════════════════
     LOCK SCREEN
══════════════════════════════════════ -->
<div id="lock-screen" role="dialog" aria-modal="true" aria-labelledby="lock-title">
  <div class="lock-card">
    <i class="ti ti-lock lock-icon" aria-hidden="true"></i>
    <div class="lock-title" id="lock-title">Workshop access</div>
    <div class="lock-sub">ITU-D Connectivity Planning Platform · Data to Visualisation</div>
    <input
      class="lock-input"
      id="pw-input"
      type="password"
      placeholder="Enter session password"
      autocomplete="current-password"
      aria-label="Session password"
    >
    <button class="lock-btn" onclick="checkPassword()" id="unlock-btn">Enter workshop</button>
    <div class="lock-error" id="lock-error" role="alert">Incorrect password. Please try again.</div>
    <div class="lock-hint">Contact your session facilitator if you need access credentials.</div>
  </div>
</div>

<!-- ══════════════════════════════════════
     MAIN APP
══════════════════════════════════════ -->
<div id="app">
  <div class="topbar">
    <i class="ti ti-wifi" aria-hidden="true" style="font-size:18px; color:var(--green);"></i>
    <div>
      <div class="topbar-brand">ITU-D · Connectivity Planning Platform</div>
      <div class="topbar-sub">Workshop — From Data to Visualisation</div>
    </div>
    <div class="topbar-right">
      <button class="btn-logout" onclick="logout()"><i class="ti ti-logout" aria-hidden="true"></i> Exit</button>
    </div>
  </div>

  <div class="main">

    <nav class="nav" role="tablist" aria-label="Workshop modules">
      <button class="nav-tab active" role="tab" aria-selected="true" onclick="showPanel('intro')"><span class="step-badge">1</span>Introduction</button>
      <button class="nav-tab" role="tab" aria-selected="false" onclick="showPanel('upload')"><span class="step-badge">2</span>Upload &amp; structure</button>
      <button class="nav-tab" role="tab" aria-selected="false" onclick="showPanel('explore')"><span class="step-badge">3</span>Explore data</button>
      <button class="nav-tab" role="tab" aria-selected="false" onclick="showPanel('map')"><span class="step-badge">4</span>Geospatial view</button>
      <button class="nav-tab" role="tab" aria-selected="false" onclick="showPanel('insights')"><span class="step-badge">5</span>Policy insights</button>
      <button class="nav-tab" role="tab" aria-selected="false" onclick="showPanel('priority')"><span class="step-badge">6</span>Prioritisation</button>
      <button class="nav-tab" role="tab" aria-selected="false" onclick="showPanel('quiz')"><span class="step-badge">7</span>Check learning</button>
    </nav>

    <!-- ── PANEL 1: INTRO ── -->
    <div class="panel active" id="panel-intro" role="tabpanel">
      <div class="intro-header">
        <div class="eyebrow">ITU-D · Connectivity Planning Platform</div>
        <h1>From data to visualisation</h1>
        <p>A hands-on workshop environment for policymakers, regulators, and national broadband planners</p>
      </div>

      <div class="card-row">
        <div class="step-card" onclick="showPanel('upload')" role="button" tabindex="0">
          <div class="step-num">1</div>
          <div class="step-content"><strong>Upload &amp; structure data</strong><p>Learn how raw connectivity datasets are organised and validated before analysis</p></div>
        </div>
        <div class="step-card" onclick="showPanel('explore')" role="button" tabindex="0">
          <div class="step-num">2</div>
          <div class="step-content"><strong>Explore &amp; filter</strong><p>Interact with coverage indicators, technology types, and demographic overlays</p></div>
        </div>
        <div class="step-card" onclick="showPanel('map')" role="button" tabindex="0">
          <div class="step-num">3</div>
          <div class="step-content"><strong>Geospatial view</strong><p>Read and interpret district-level connectivity maps to identify coverage gaps</p></div>
        </div>
        <div class="step-card" onclick="showPanel('insights')" role="button" tabindex="0">
          <div class="step-num">4</div>
          <div class="step-content"><strong>Policy insights</strong><p>Translate visual patterns into actionable recommendations for broadband planning</p></div>
        </div>
        <div class="step-card" onclick="showPanel('priority')" role="button" tabindex="0">
          <div class="step-num">5</div>
          <div class="step-content"><strong>Prioritise interventions</strong><p>Apply weighting criteria to rank districts for Universal Service Fund allocation</p></div>
        </div>
        <div class="step-card" onclick="showPanel('quiz')" role="button" tabindex="0">
          <div class="step-num">6</div>
          <div class="step-content"><strong>Check your learning</strong><p>Consolidate understanding with scenario-based questions and instant feedback</p></div>
        </div>
      </div>

      <div class="section-label">What is CPP?</div>
      <div class="card">
        <div style="font-size:14px;font-weight:500;margin-bottom:0.5rem;">What is the ITU-D Connectivity Planning Platform?</div>
        <p style="font-size:13px;color:var(--text-secondary);line-height:1.7;margin-bottom:0.75rem;">The ITU-D Connectivity Planning Platform (CPP) is a web-based geospatial tool developed by the ITU Telecommunication Development Bureau to help governments and regulators turn raw connectivity data into decision-ready visualisations. It supports evidence-based broadband planning by mapping coverage gaps, overlaying demographic and economic data, and helping policymakers identify where universal service interventions will have the greatest impact.</p>
        <div style="display:flex;gap:8px;flex-wrap:wrap;">
          <span class="tag tag-green"><i class="ti ti-database" aria-hidden="true"></i> Data ingestion</span>
          <span class="tag tag-blue"><i class="ti ti-map" aria-hidden="true"></i> Geospatial mapping</span>
          <span class="tag tag-amber"><i class="ti ti-chart-bar" aria-hidden="true"></i> Gap analysis</span>
          <span class="tag tag-red"><i class="ti ti-target" aria-hidden="true"></i> Intervention targeting</span>
        </div>
      </div>

      <div class="card-4">
        <div class="metric"><div class="metric-label">Countries using ITU-D CPP</div><div class="metric-value">47</div><div class="metric-sub">across 5 ITU regions</div></div>
        <div class="metric"><div class="metric-label">Average coverage gap identified</div><div class="metric-value">23%</div><div class="metric-sub">of population unserved</div></div>
        <div class="metric"><div class="metric-label">USF allocation efficiency gain</div><div class="metric-value">38%</div><div class="metric-sub">vs. non-data-driven planning</div></div>
        <div class="metric"><div class="metric-label">Policy cycle time reduction</div><div class="metric-value">2×</div><div class="metric-sub">faster with CPP dashboards</div></div>
      </div>

      <div class="action-row">
        <button class="btn-primary" onclick="showPanel('upload')">Begin the workshop <i class="ti ti-arrow-right" aria-hidden="true"></i></button>
      </div>
    </div>

    <!-- ── PANEL 2: UPLOAD ── -->
    <div class="panel" id="panel-upload" role="tabpanel">
      <div class="section-label">Step 2 — Upload &amp; structure your dataset in CPP</div>

      <div class="upload-zone" id="upload-zone" onclick="simulateUpload()" role="button" tabindex="0" aria-label="Upload connectivity dataset or load sample">
        <i class="ti ti-upload" id="upload-icon" aria-hidden="true"></i>
        <div style="font-size:15px;font-weight:500;margin-bottom:4px;" id="upload-title">Upload connectivity dataset</div>
        <p id="upload-desc">Click to select a .csv or .xlsx file · or drag and drop here</p>
        <p style="font-size:11px;color:var(--text-tertiary);margin-top:6px;" id="upload-hint">CPP accepts: operator coverage returns, national survey data, ITU-format district datasets</p>
      </div>

      <div style="margin:1rem 0;text-align:center;font-size:12px;color:var(--text-tertiary);">— or use the pre-loaded sample dataset —</div>
      <div id="load-sample-btn" style="text-align:center;">
        <button class="btn-primary" onclick="loadSample()"><i class="ti ti-database" aria-hidden="true"></i> Load sample dataset</button>
      </div>

      <div id="dataset-info" style="display:none;margin-top:1rem;">
        <div class="card" style="border-color:#5DCAA5;">
          <div style="display:flex;align-items:center;gap:10px;margin-bottom:0.75rem;">
            <i class="ti ti-file-check" aria-hidden="true" style="font-size:20px;color:var(--green);"></i>
            <div>
              <div style="font-size:14px;font-weight:500;">sample_coverage_dataset.csv</div>
              <div style="font-size:12px;color:var(--text-secondary);">18 districts · 9 variables · 2023 reporting period</div>
            </div>
            <span class="tag tag-green" style="margin-left:auto;">Validated</span>
          </div>
